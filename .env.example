# ============================================================
# TTHC RAG — Environment Configuration
# ============================================================

# --- Embedding Provider ---
# Chọn 1 trong 3: mock | openai | llamacpp
# mock: hash-based (không cần server, dùng cho test/CI)
# openai: text-embedding-3-small (cần API key)
# llamacpp: VietLegal-Harrier GGUF (cần llama-server local)
EMBEDDING_PROVIDER=mock

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-5.4-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- LlamaCpp (VietLegal-Harrier) ---
# Khởi động server: bash scripts/start_embedding_server.sh
# LLAMACPP_SERVER_URL=http://localhost:8086

# --- LM Studio (alternative local embedding) ---
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_EMBEDDING_MODEL=vietlegal-harrier-0.6b

# --- Weaviate Cloud (production vector DB) ---
# WEAVIATE_URL=https://your-cluster.weaviate.cloud
# WEAVIATE_API_KEY=your-key-here
